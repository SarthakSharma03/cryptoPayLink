{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "rootDir": "./src",
     "jsx": "react-jsx",
    "outDir": "./dist",
    "typeRoots": [
      "src/types",
      "./node_modules/@types"
    ],
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "include": [
    "src",
    "src/**/*.json",
    "../env"
  ],
  "exclude": [
    "src/testing",
    "src/**/*.test.ts"
  ]
}
